<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="내신 퍼센트 계산기"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="학교·학년별 등록된 퍼센트 표로만 계산합니다. 미등록 시 요청하기로 사진을 올려 주세요."
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilGradeSchoolSelect"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/school_select_hint">

            <AutoCompleteTextView
                android:id="@+id/gradeSchoolSelect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/gradeSchoolResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/gradeSelectedSchoolText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="선택된 학교: 없음"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="학년 (1~3)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/gradeLevelInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="1"
                android:text="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/gradeCheckButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="학년 확인" />

        <TextView
            android:id="@+id/gradeStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="학교와 학년을 선택한 뒤 확인해 주세요."
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp" />

        <!-- Request panel: shown when NOT ready -->
        <LinearLayout
            android:id="@+id/gradeRequestPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="이 학년 퍼센트 표가 아직 등록되지 않았습니다."
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="학교 퍼센트 표 사진을 올리면 관리자가 확인 후 등록합니다."
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/gradeRequestButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="요청하기 (사진 선택)" />

            <TextView
                android:id="@+id/gradeRequestStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Calculator panel: shown when ready -->
        <LinearLayout
            android:id="@+id/gradeCalculatorPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="과목별 점수 입력"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="등록된 퍼센트 표 기준으로 계산합니다."
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/gradeSubjectInputs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />

            <Button
                android:id="@+id/gradeAddSubjectButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="+ 과목 추가" />

            <Button
                android:id="@+id/gradeCalculateButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="퍼센트 계산" />

            <TextView
                android:id="@+id/gradeResultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
